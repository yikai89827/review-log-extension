{
  "name": "review-log-extension",
  "version": "0.2.1",
  "description": "A Chrome extension that captures console logs, deduplicates repeated entries, displays them in a Gemini-style side panel, and supports AI-powered analysis.",
  "scripts": {
    "dev": "plasmo dev --environment development",
    "build": "plasmo build --environment development",
    "build:dev": "plasmo build --environment development",
    "build:prod": "plasmo build --environment production",
    "package": "plasmo package --environment development",
    "package:dev": "plasmo package --environment development",
    "package:prod": "plasmo package --environment production",
    "preview": "plasmo preview"
  },
  "dependencies": {
    "plasmo": "0.90.5",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@plasmohq/parcel-config": "0.40.0",
    "@types/chrome": "0.0.270",
    "@types/node": "20.16.5",
    "@types/react": "18.3.5",
    "@types/react-dom": "18.3.0",
    "dotenv": "^17.4.2",
    "typescript": "5.5.4"
  },
  "manifest": {
    "name": "Review Log",
    "description": "Capture, deduplicate and AI-analyze console logs in a Gemini-style side panel.",
    "host_permissions": [
      "<all_urls>"
    ],
    "permissions": [
      "sidePanel",
      "tabs",
      "storage",
      "scripting"
    ]
  }
}

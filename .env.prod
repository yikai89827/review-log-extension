# Review Log Configuration

# ================ 自建服务器配置 ================
# 默认服务器地址（移动端 SDK 连接地址）
PLASMO_PUBLIC_SELF_HOSTED_SERVER_URL=

# ================ GoEasy 云服务配置 ================
# 获取 appkey: https://www.goeasy.io 注册并创建应用
PLASMO_PUBLIC_GOEASY_APPKEY=
PLASMO_PUBLIC_GOEASY_HOST=
PLASMO_PUBLIC_GOEASY_CHANNEL=

# ================ 默认连接模式 ================
# 可选值: self-hosted | goeasy
PLASMO_PUBLIC_DEFAULT_CONNECTION_MODE=self-hosted
